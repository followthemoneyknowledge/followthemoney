# Follow the Money — environment variables
# Copy to .env and fill in your keys

# ── OpenRouter (required) ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-opus-4-5   # optional override

# ── ElevenLabs TTS (optional — falls back to edge-tts if not set) ─────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=LXu5MIFyvPZCxBst8fPP    # default voice ID
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5        # default model

# ── edge-tts fallback voice (optional) ────────────────────────────────────────
EDGE_TTS_VOICE=en-US-GuyNeural               # male — change to en-US-AriaNeural for female

# ── Buffer (required for post_to_buffer.py) ────────────────────────────────────
BUFFER_TOKEN=your_buffer_access_token_here
BUFFER_INSTAGRAM_ID=your_buffer_instagram_channel_id
BUFFER_TIKTOK_ID=your_buffer_tiktok_channel_id     # optional
BUFFER_LINKEDIN_ID=your_buffer_linkedin_channel_id  # optional

# ── GitHub (required for post_to_buffer.py — hosts the video publicly) ────────
# The gh CLI must be authenticated: gh auth login
GITHUB_REPO=followthemoneyknowledge/followthemoney
